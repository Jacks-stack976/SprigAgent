# Vertex AI / Gemini — only needed for the opt-in REAL eval path (SPRIG_DRIVER=vertex).
# The default offline path (SPRIG_DRIVER unset or =stub) needs none of these.
# Authenticate ADC first with: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=          # e.g. my-gcp-project
GOOGLE_CLOUD_LOCATION=         # e.g. us-central1
VERTEX_MODEL=                  # e.g. gemini-2.0-flash-001
# Eval driver selector: stub (default, offline/free) | vertex (real, paid) | replay (offline cache)
SPRIG_DRIVER=
# GitHub MCP
GITHUB_TOKEN=
